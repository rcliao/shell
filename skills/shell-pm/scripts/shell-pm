#!/bin/sh
# shell-pm — process manager skill script
# Calls the bridge RPC server via Unix socket.
set -e

SOCK="${SHELL_BRIDGE_SOCK:-$HOME/.shell/bridge.sock}"
URL="http://bridge/pm"

ACTION=""
NAME=""
CMD=""
DIR=""

while [ $# -gt 0 ]; do
  case "$1" in
    start|stop|list|logs|remove) ACTION="$1"; shift ;;
    --name) NAME="$2"; shift 2 ;;
    --cmd)  CMD="$2"; shift 2 ;;
    --dir)  DIR="$2"; shift 2 ;;
    *) echo "unknown arg: $1" >&2; exit 1 ;;
  esac
done

if [ -z "$ACTION" ]; then
  ACTION="list"
fi

BODY=$(cat <<EOF
{"action":"$ACTION","name":"$NAME","command":"$CMD","dir":"$DIR"}
EOF
)

RESP=$(curl -s --unix-socket "$SOCK" "$URL" -X POST -H "Content-Type: application/json" -d "$BODY")

# Check for error
if echo "$RESP" | grep -q '"error"'; then
  echo "$RESP" | python3 -c "import sys,json; print(json.load(sys.stdin).get('error',''))" 2>/dev/null || echo "$RESP"
  exit 1
fi

echo "$RESP" | python3 -c "import sys,json; print(json.load(sys.stdin).get('result',''))" 2>/dev/null || echo "$RESP"
