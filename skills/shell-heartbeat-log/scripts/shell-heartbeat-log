#!/bin/sh
# shell-heartbeat-log — inspect recent heartbeat activity from the system chat
set -e

SOCK="${SHELL_BRIDGE_SOCK:-$HOME/.shell/bridge.sock}"
URL="http://bridge/heartbeat-log"

LIMIT=10
FULL=false

while [ $# -gt 0 ]; do
  case "$1" in
    --limit) LIMIT="$2"; shift 2 ;;
    --full)  FULL=true; shift ;;
    -h|--help)
      echo "usage: shell-heartbeat-log [--limit N] [--full]" >&2
      exit 0
      ;;
    *) echo "unknown arg: $1" >&2; exit 1 ;;
  esac
done

BODY=$(python3 -c "
import json
print(json.dumps({'limit': int('$LIMIT'), 'full': $FULL}))
")

RESP=$(curl -s --unix-socket "$SOCK" "$URL" -X POST -H "Content-Type: application/json" -d "$BODY")

if echo "$RESP" | grep -q '"error"'; then
  echo "$RESP" | python3 -c "import sys,json; print(json.load(sys.stdin).get('error',''))" 2>/dev/null || echo "$RESP"
  exit 1
fi

# Format the response
python3 -c "
import sys, json
r = json.loads(sys.stdin.read())
entries = r.get('entries', [])
if not entries:
    print(r.get('note', 'No heartbeat activity yet.'))
    sys.exit(0)

# Reverse so oldest is first (more readable)
entries.reverse()

print(f'Recent heartbeat activity ({len(entries)} entries from system chat):')
print('=' * 60)
for e in entries:
    ts = e['timestamp']
    role = e['role']
    kind = e.get('kind', '')
    content = e['content']
    if role == 'user':
        if kind == 'deep':
            print(f'\n[{ts}] >>> DEEP HEARTBEAT')
        elif kind == 'regular':
            print(f'\n[{ts}] >>> regular heartbeat')
        else:
            print(f'\n[{ts}] >>> {content}')
    else:
        # indent assistant lines
        for line in content.split('\n'):
            print(f'  → {line}')
" <<< "$RESP"
