#!/bin/sh
# shell-task — create, complete, and manage tasks for self-decomposition and agent delegation
set -e

SOCK="${SHELL_BRIDGE_SOCK:-$HOME/.shell/bridge.sock}"
URL="http://bridge/task"
CHAT_ID="${SHELL_CHAT_ID:-0}"
BOT_USERNAME="${SHELL_BOT_USERNAME:-}"

# Parse subcommand
ACTION=""
if [ $# -gt 0 ]; then
  case "$1" in
    create|complete|fail|list|status) ACTION="$1"; shift ;;
    *) ;;
  esac
fi

# Parse flags
TO=""
DESCRIPTION=""
CONTEXT=""
GOAL_ID=""
TASK_ID=""
RESULT=""
REASON=""

while [ $# -gt 0 ]; do
  case "$1" in
    --to)          TO="$2"; shift 2 ;;
    --description) DESCRIPTION="$2"; shift 2 ;;
    --context)     CONTEXT="$2"; shift 2 ;;
    --goal)        GOAL_ID="$2"; shift 2 ;;
    --id)          TASK_ID="$2"; shift 2 ;;
    --result)      RESULT="$2"; shift 2 ;;
    --reason)      REASON="$2"; shift 2 ;;
    --chat)        CHAT_ID="$2"; shift 2 ;;
    *) echo "unknown arg: $1" >&2; exit 1 ;;
  esac
done

if [ -z "$ACTION" ]; then
  echo "usage: shell-task <create|complete|fail|list|status> [options]" >&2
  echo "" >&2
  echo "  create   --to <agent|self> --description \"...\" [--context \"...\"] [--goal <id>]" >&2
  echo "  complete --id <task_id> --result \"...\"" >&2
  echo "  fail     --id <task_id> --reason \"...\"" >&2
  echo "  list" >&2
  echo "  status   --id <task_id>" >&2
  exit 1
fi

# Build JSON body using python3 for proper escaping
BODY=$(python3 -c "
import json, sys
d = {'action': '$ACTION', 'chat_id': int('$CHAT_ID')}
to = '''$TO'''
desc = '''$DESCRIPTION'''
ctx = '''$CONTEXT'''
goal = '''$GOAL_ID'''
tid = '''$TASK_ID'''
result = '''$RESULT'''
reason = '''$REASON'''
if to: d['to'] = to
if desc: d['description'] = desc
if ctx: d['context'] = ctx
if goal: d['goal_id'] = goal
if tid: d['task_id'] = tid
if result: d['result'] = result
if reason: d['reason'] = reason
print(json.dumps(d))
")

RESP=$(curl -s --unix-socket "$SOCK" "$URL" -X POST -H "Content-Type: application/json" -d "$BODY")

# Check for errors
if echo "$RESP" | python3 -c "import sys,json; d=json.load(sys.stdin); sys.exit(0 if d.get('ok') else 1)" 2>/dev/null; then
  # Success — format output based on action
  case "$ACTION" in
    create)
      TASK_ID=$(echo "$RESP" | python3 -c "import sys,json; print(json.load(sys.stdin).get('task_id',''))")
      echo "Task created: $TASK_ID"
      ;;
    complete)
      echo "Task $TASK_ID completed."
      ;;
    fail)
      echo "Task $TASK_ID marked as failed."
      ;;
    list)
      echo "$RESP" | python3 -c "
import sys, json
d = json.load(sys.stdin)
tasks = d.get('tasks') or []
if not tasks:
    print('No pending tasks.')
else:
    for t in tasks:
        src = 'self' if t['from'] == t['to'] else t['from']
        print(f\"- {t['id'][:12]} ({src}): {t['description']}\")
    print(f\"\n{d['count']} pending task(s).\")
"
      ;;
    status)
      echo "$RESP" | python3 -c "
import sys, json
t = json.load(sys.stdin)
print(f\"Task: {t['id']}\")
print(f\"From: {t['from']} → To: {t['to']}\")
print(f\"Status: {t['status']}\")
print(f\"Description: {t['description']}\")
if t.get('context'): print(f\"Context: {t['context']}\")
if t.get('result'): print(f\"Result: {t['result']}\")
if t.get('goal_id'): print(f\"Goal: {t['goal_id']}\")
"
      ;;
  esac
else
  # Error
  echo "$RESP" | python3 -c "import sys,json; print(json.load(sys.stdin).get('error','unknown error'))" 2>/dev/null || echo "$RESP"
  exit 1
fi
